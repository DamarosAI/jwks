# Contact form — Vercel Project Settings → Environment Variables
#
# Delivery works without these via FormSubmit (emails land at CONTACT_TO_*).
# First submission to a new inbox can require clicking FormSubmit's activation
# link in that mailbox. After that, every inquiry arrives as email.
#
# Optional upgrade: Resend for branded From addresses.
# https://resend.com → API key → verify damaros.ai → set CONTACT_FROM

RESEND_API_KEY=
CONTACT_FROM=Damaros <forms@damaros.ai>
CONTACT_TO_PILOT=team@damaros.ai
CONTACT_TO_FOUNDER=anirudh@damaros.ai
CONTACT_TO_PRIVACY=team@damaros.ai
