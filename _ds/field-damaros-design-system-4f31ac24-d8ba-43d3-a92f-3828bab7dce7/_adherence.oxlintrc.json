{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/forms/**",
              "components/status/**",
              "components/workflow/**",
              "ui_kits/console/**",
              "ui_kits/node/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Archivo|Hanken Grotesk|IBM Plex Mono|Chakra Petch|Plus Jakarta Sans))/i]",
        "message": "Font not provided by the design system. Available: Archivo, Hanken Grotesk, IBM Plex Mono, Chakra Petch, Plus Jakarta Sans."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|variant|size|loading|shortcut|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: tone, variant, size, loading, shortcut."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|interactive|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant, interactive, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:muted|steel|cold)$/]",
        "message": "<Eyebrow> tone must be one of 'muted' | 'steel' | 'cold'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:error|helperText|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: error, helperText."
      },
      {
        "selector": "JSXOpeningElement[name.name='Kbd'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|key|ref|className|style|children)$/]",
        "message": "<Kbd> doesn't accept that prop. Declared props: children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ReviewChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|cta|driver|onResolve|key|ref|className|style|children)$/]",
        "message": "<ReviewChip> doesn't accept that prop. Declared props: label, cta, driver, onResolve."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|size|children|key|ref|className|style|children)$/]",
        "message": "<StatusBadge> doesn't accept that prop. Declared props: status, size, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<StatusBadge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stepper'] > JSXAttribute > JSXIdentifier[name!=/^(?:steps|current|onStep|key|ref|className|style|children)$/]",
        "message": "<Stepper> doesn't accept that prop. Declared props: steps, current, onStep."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrustPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|children|key|ref|className|style|children)$/]",
        "message": "<TrustPill> doesn't accept that prop. Declared props: tone, dot, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrustPill'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:ok|warn|steel|muted)$/]",
        "message": "<TrustPill> tone must be one of 'ok' | 'warn' | 'steel' | 'muted'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
