{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/.well-known/jwks-prod.json",
      "destination": "/jwks/jwks-prod.json"
    },
    {
      "source": "/.well-known/jwks-nonprod.json",
      "destination": "/jwks/jwks-nonprod.json"
    },
    {
      "source": "/favicon.ico",
      "destination": "/assets/damaros-favicon.png"
    }
  ],
  "headers": [
    {
      "source": "/((?!assets/|_ds/|uploads/).*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/(_ds|uploads)/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/.well-known/jwks-prod.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/.well-known/jwks-nonprod.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json; charset=utf-8" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/jwks/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "application/json; charset=utf-8" }
      ]
    }
  ]
}
